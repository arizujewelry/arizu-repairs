# ====================================
# Arizu Jewelry — Repair Management
# ====================================

# Port for the server (default: 3001)
PORT=3001

# Secret key for JWT tokens - CHANGE THIS in production!
JWT_SECRET=arizu-super-secret-jwt-key-change-this

# Resend API Key for sending emails
# Get your free key at: https://resend.com
# Free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx

# From email (must be verified in Resend)
FROM_EMAIL=INFO@ARIZU.CO.IL
FROM_NAME=אריזו תכשיטים

# Client URL (for CORS) - set to your frontend URL in production
CLIENT_URL=http://localhost:5173
